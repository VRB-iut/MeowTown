generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                    Int       @id @default(autoincrement())
  username              String    @unique
  password              String
  profilePictureUrl     String? 
  darkMode              Boolean   @default(false)
  backButtonPossition   Boolean   @default(false)
  catPoints             Int       @default(0)
  dogPoints             Int       @default(0)
  createdAt             DateTime  @default(now())
  posts                 Post[]
  likes                 PostLike[]
}

model Post {
  id        Int       @id @default(autoincrement())
  sameCat   Boolean   @default(false)
  byWho     String?
  imageUrl  String
  thumbnailUrl String
  embedding String?
  userId    Int
  latitude  Float
  longitude Float
  likes     Int       @default(0)
  user      User      @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())
  likedBy   PostLike[]
}

model PostLike {
  id     Int  @id @default(autoincrement())
  user   User @relation(fields: [userId], references: [id])
  userId Int
  post   Post @relation(fields: [postId], references: [id])
  postId Int

  @@unique([userId, postId])
}